MANAGED_AGENT_RUNNER_HOST=127.0.0.1
# Remote VPS + Tailscale/VPN: panel must reach this host; loopback does not answer on 100.x.y.z.
# Use 0.0.0.0 only with firewall restricting tcp/9000 (e.g. ufw allow from 100.64.0.0/10).
# Or run: MANAGED_AGENT_TAILSCALE_BIND=1 sudo -E managed-deploy join https://YOUR_PANEL (sets 0.0.0.0 when host vars are unset).
MANAGED_AGENT_RUNNER_PORT=9000
MANAGED_AGENT_RUNNER_KEY=CHANGE_ME
MANAGED_AGENT_RUNNER_LOG=/var/log/managed-deploy-agent.log
RELEASEPANEL_RUNNER_HOST=127.0.0.1
RELEASEPANEL_RUNNER_PORT=9000
RELEASEPANEL_RUNNER_KEY=CHANGE_ME
RELEASEPANEL_RUNNER_LOG=/var/log/managed-deploy-agent.log
# Path to the private deploy checkout (sites/, scripts/, bin/releasepanel). Required when this agent is installed outside that repo (e.g. public clone at /opt/managed-deploy-agent with toolkit at /opt/releasepanel-deploy). Leave unset when running from deploy's runner/ directory.
# MANAGED_AGENT_TOOLKIT_DIR=/opt/releasepanel-deploy
# RELEASEPANEL_TOOLKIT_DIR=/opt/releasepanel-deploy
MANAGED_AGENT_RUNNER_NORMAL_TIMEOUT_MS=120000
MANAGED_AGENT_RUNNER_DEPLOY_TIMEOUT_MS=900000
MANAGED_AGENT_PANEL_URL=
MANAGED_AGENT_RUNNER_PUBLIC_URL=
MANAGED_AGENT_RUNNER_HEARTBEAT_MS=30000
RELEASEPANEL_RUNNER_NORMAL_TIMEOUT_MS=120000
RELEASEPANEL_RUNNER_DEPLOY_TIMEOUT_MS=900000
RELEASEPANEL_PANEL_URL=
RELEASEPANEL_RUNNER_PUBLIC_URL=
RELEASEPANEL_RUNNER_HEARTBEAT_MS=30000

# Log each GET /health to stderr (journalctl). File log always records requester_ip.
# MANAGED_AGENT_LOG_HEALTH_IP=1

# Self-signed HTTPS control plane: disable TLS verify for heartbeats (staging only). Bootstrap/join may set this only when curl TLS verify fails with exit 60/51 against a private CA.
# MANAGED_AGENT_PANEL_INSECURE_TLS=1
# RELEASEPANEL_PANEL_INSECURE_TLS=1
# Public Let's Encrypt panels should leave these unset. Optional: never auto-export insecure TLS from join-panel (private CA then requires manual exports below).
# MANAGED_AGENT_DISABLE_AUTO_INSECURE_TLS=1
# RELEASEPANEL_DISABLE_AUTO_INSECURE_TLS=1

# Outbound poll mode: agent pulls deploy jobs from the panel over HTTPS (no inbound runner_url required for execution).
# Mirrors MANAGED_AGENT_* / RELEASEPANEL_* naming used elsewhere.
# MANAGED_AGENT_POLL_ENABLED=true
# MANAGED_AGENT_POLL_INTERVAL_SECONDS=5
# RELEASEPANEL_POLL_ENABLED=true
# RELEASEPANEL_POLL_INTERVAL_SECONDS=5
