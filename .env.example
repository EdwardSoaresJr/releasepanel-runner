# Optional: reported to the control plane on each heartbeat (updates server row when set).
# MANAGED_AGENT_RUNNER_PUBLIC_IP=203.0.113.10

# Toolkit path (defaults to ./toolkit next to server.js when unset).
MANAGED_AGENT_TOOLKIT_DIR=/opt/managed-deploy-agent/toolkit
# Legacy alias (same path); still read by older scripts.
RELEASEPANEL_TOOLKIT_DIR=/opt/managed-deploy-agent/toolkit

MANAGED_AGENT_RUNNER_HOST=127.0.0.1
MANAGED_AGENT_RUNNER_PORT=9000
MANAGED_AGENT_RUNNER_KEY=CHANGE_ME
MANAGED_AGENT_RUNNER_LOG=/var/log/managed-deploy-agent.log
MANAGED_AGENT_RUNNER_NORMAL_TIMEOUT_MS=120000
MANAGED_AGENT_RUNNER_DEPLOY_TIMEOUT_MS=900000
MANAGED_AGENT_PANEL_URL=
MANAGED_AGENT_RUNNER_PUBLIC_URL=
MANAGED_AGENT_RUNNER_HEARTBEAT_MS=30000

# HTTPS control plane with a self-signed or private CA cert: disable TLS verification for heartbeats (staging only).
# MANAGED_AGENT_PANEL_INSECURE_TLS=1
# RELEASEPANEL_PANEL_INSECURE_TLS=1

# Legacy aliases (optional; agent reads MANAGED_AGENT_* first).
# RELEASEPANEL_RUNNER_HOST=
# RELEASEPANEL_RUNNER_KEY=

# Optional: if the panel URL uses a self-signed cert, set for registration only (bootstrap-runner).
# SECURITY: only use on trusted networks / staging; prefer a real TLS cert on the panel.
# MANAGED_AGENT_REGISTER_INSECURE_TLS=1
# RELEASEPANEL_REGISTER_INSECURE_TLS=1
