#!/usr/bin/env bash
set -Eeuo pipefail

THIS="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname "${THIS}")"
CLI_NAME="$(basename "${0}")"

if [ "$(basename "${SCRIPT_DIR}")" = "bin" ] && [ -d "${SCRIPT_DIR}/../scripts" ]; then
    TOOLKIT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
elif [ "${CLI_NAME}" = "managed-deploy" ]; then
    TOOLKIT_DIR=""
    if [ -n "${MANAGED_AGENT_TOOLKIT_DIR:-}" ] && [ -d "${MANAGED_AGENT_TOOLKIT_DIR}/scripts" ]; then
        TOOLKIT_DIR="${MANAGED_AGENT_TOOLKIT_DIR}"
    elif [ -n "${RELEASEPANEL_TOOLKIT_DIR:-}" ] && [ -d "${RELEASEPANEL_TOOLKIT_DIR}/scripts" ]; then
        TOOLKIT_DIR="${RELEASEPANEL_TOOLKIT_DIR}"
    elif [ -d "/opt/managed-deploy-agent/toolkit/scripts" ]; then
        TOOLKIT_DIR="/opt/managed-deploy-agent/toolkit"
    elif [ -d "/opt/managed-deploy-agent/scripts" ]; then
        TOOLKIT_DIR="/opt/managed-deploy-agent"
    elif [ -d "/opt/releasepanel-runner/toolkit/scripts" ]; then
        TOOLKIT_DIR="/opt/releasepanel-runner/toolkit"
    fi
    if [ -z "${TOOLKIT_DIR}" ]; then
        echo "[error] ${CLI_NAME}: toolkit not found (need a directory containing scripts/). Set MANAGED_AGENT_TOOLKIT_DIR." >&2
        exit 1
    fi
else
    TOOLKIT_DIR="${RELEASEPANEL_TOOLKIT_DIR:-${MANAGED_AGENT_TOOLKIT_DIR:-/opt/releasepanel-deploy}}"
fi

usage() {
    local title
    if [ "${CLI_NAME}" = "managed-deploy" ]; then
        title="Managed Deploy Agent — operator CLI (runtime stack + deploy hooks). Control plane UI is optional."
    else
        title="ReleasePanel deploy toolkit — master host & operator CLI."
    fi

    cat <<EOF
${title}

Usage:
  ${CLI_NAME} self-update [--hard]
  ${CLI_NAME} bootstrap
  ${CLI_NAME} bootstrap-runner
  ${CLI_NAME} bootstrap-releasepanel
  ${CLI_NAME} heal-self-runner
  ${CLI_NAME} mysql status
  ${CLI_NAME} redis status
  ${CLI_NAME} install-php <php-version>
  ${CLI_NAME} menu [install-login-hook|uninstall-login-hook]
  ${CLI_NAME} create-admin
  ${CLI_NAME} runner
  ${CLI_NAME} sync-runner
  ${CLI_NAME} join <panel-url>
  ${CLI_NAME} server register <panel-url> [server-name] [runner-url]
  ${CLI_NAME} workers install|restart|status <site> <environment>
  ${CLI_NAME} site <command> <site> <environment> [options]
  ${CLI_NAME} site promote <site> <from-environment> <to-environment>

Site commands:
  deploy [--skip-route-cache|--strict]
  preflight
  status
  rollback
  user
  deploy-key
  repair
  nginx
  ssl
  workers
  smoke
  pdf
  harden

Examples:
  ${CLI_NAME} bootstrap-runner
  ${CLI_NAME} join https://panel.example.com
  ${CLI_NAME} runner
  ${CLI_NAME} sync-runner
  ${CLI_NAME} server register https://panel.example.com
  ${CLI_NAME} site deploy demo-app production
EOF
}

if [ $# -lt 1 ]; then
    usage
    exit 0
fi

first_arg="$1"
shift

run_script() {
    local script="$1"
    shift

    exec bash "${TOOLKIT_DIR}/scripts/${script}" "$@"
}

resolve_site_env_arg() {
    local site_env="$1"
    local env_file
    local site
    local env

    for env_file in "${TOOLKIT_DIR}/sites/"*/*.env; do
        [ -e "${env_file}" ] || continue

        env="$(basename "${env_file}" .env)"
        site="$(basename "$(dirname "${env_file}")")"

        if [ "${site}-${env}" = "${site_env}" ]; then
            site_slug="${site}"
            env_slug="${env}"
            return 0
        fi
    done

    return 1
}

run_site_env_script() {
    local script="$1"
    local site_slug="$2"
    local env_slug="$3"
    shift 3

    RELEASEPANEL_DEPLOY_ENV="${TOOLKIT_DIR}/sites/${site_slug}/${env_slug}.env" \
        exec bash "${TOOLKIT_DIR}/scripts/${script}" "${site_slug}-${env_slug}" "$@"
}

case "${first_arg}" in
    self-update)
        run_script self-update.sh "$@"
        ;;
    bootstrap)
        run_script 01-bootstrap.sh "$@"
        ;;
    bootstrap-runner)
        run_script bootstrap-runner.sh "$@"
        ;;
    bootstrap-releasepanel)
        run_script bootstrap-releasepanel.sh "$@"
        ;;
    heal-self-runner)
        RELEASEPANEL_DEPLOY_ENV="${TOOLKIT_DIR}/sites/releasepanel-app/production.env" \
            exec bash "${TOOLKIT_DIR}/scripts/heal-releasepanel-self-runner.sh"
        ;;
    mysql)
        case "${1:-status}" in
            status)
                shift || true
                run_script mysql-status.sh status "$@"
                ;;
            -h | --help | help)
                echo "Usage: ${CLI_NAME} mysql status" >&2
                ;;
            *)
                echo "[error] Unknown mysql subcommand: ${1:-}" >&2
                exit 1
                ;;
        esac
        ;;
    redis)
        case "${1:-status}" in
            status)
                shift || true
                run_script redis-status.sh "$@"
                ;;
            -h | --help | help)
                echo "Usage: ${CLI_NAME} redis status" >&2
                ;;
            *)
                echo "[error] Unknown redis subcommand: ${1:-}" >&2
                exit 1
                ;;
        esac
        ;;
    install-php)
        if [ $# -ne 1 ]; then
            usage >&2
            exit 1
        fi
        run_script install-php-runtime.sh "$1"
        ;;
    menu)
        case "${1:-}" in
            install-login-hook)
                bash "${TOOLKIT_DIR}/scripts/install-releasepanel-login-menu.sh" install
                ;;
            uninstall-login-hook)
                bash "${TOOLKIT_DIR}/scripts/install-releasepanel-login-menu.sh" uninstall
                ;;
            *)
                exec bash "${TOOLKIT_DIR}/bin/releasepanel-menu" "$@"
                ;;
        esac
        ;;
    create-admin)
        run_script panel-create-admin.sh "$@"
        ;;
    runner)
        run_script install-runner.sh "$@"
        ;;
    sync-runner)
        run_script sync-releasepanel-runner.sh "$@"
        ;;
    join)
        run_script join-panel.sh "$@"
        ;;
    server)
        if [ "${1:-}" != "register" ]; then
            usage >&2
            exit 1
        fi
        shift
        run_script register-server.sh "$@"
        ;;
    workers)
        if [ $# -lt 3 ]; then
            echo "[error] Usage: ${CLI_NAME} workers install|restart|status <site> <environment>" >&2
            usage >&2
            exit 1
        fi
        w_cmd="$1"
        shift
        bash "${TOOLKIT_DIR}/scripts/workers-panel.sh" "${w_cmd}" "$@"
        ;;
    site)
        if [ $# -lt 2 ]; then
            usage >&2
            exit 1
        fi

        command_name="$1"
        shift

        if [ "${command_name}" = "promote" ]; then
            if [ $# -ne 3 ]; then
                usage >&2
                exit 1
            fi

            site_slug="$1"
            env_slug="$2"
            promote_target_env="$3"
            shift 3
        elif [ $# -ge 2 ] && printf '%s' "$1" | grep -Eq '^[A-Za-z0-9_-]+$' && printf '%s' "$2" | grep -Eq '^[A-Za-z0-9_-]+$'; then
            site_slug="$1"
            env_slug="$2"
            shift 2
        elif resolve_site_env_arg "$1"; then
            shift
        else
            echo "[error] Missing site environment config for: $1" >&2
            usage >&2
            exit 1
        fi

        case "${command_name}" in
            deploy)
                run_script site-deploy.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            preflight)
                run_site_env_script 00-preflight.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            status)
                run_script site-status.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            rollback)
                run_script site-rollback.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            repair)
                run_script site-repair.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            user)
                run_site_env_script 02-create-app-user.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            deploy-key)
                run_script site-deploy-key.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            nginx)
                run_script site-nginx.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            selfsigned-nginx)
                echo "[error] Self-signed TLS for customer sites is not supported. Use HTTP-only (RELEASEPANEL_TLS_MODE=none) or enable Let's Encrypt: releasepanel site ssl ${site_slug} ${env_slug}" >&2
                exit 1
                ;;
            ssl)
                run_script site-ssl.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            workers)
                run_script site-workers.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            smoke)
                run_script site-smoke.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            pdf)
                run_site_env_script 10-pdf-stack.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            harden)
                run_site_env_script 11-security-hardening.sh "${site_slug}" "${env_slug}" "$@"
                ;;
            promote)
                run_script site-promote.sh "${site_slug}" "${env_slug}" "${promote_target_env}"
                ;;
            *)
                echo "[error] Unknown site command: ${command_name}" >&2
                usage >&2
                exit 1
                ;;
        esac
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        echo "[error] Unknown command: ${first_arg}" >&2
        usage >&2
        exit 1
        ;;
esac
